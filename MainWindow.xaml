<Window x:Class="BpmMeasurer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lex="http://wpflocalizeextension.codeplex.com"
        xmlns:local="clr-namespace:BpmMeasurer.Controls"
        lex:LocalizeDictionary.DesignCulture="zh-CN"
        lex:ResxLocalizationProvider.DefaultAssembly="Bpm Measurer"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
        Title="{lex:Loc WindowTitle}" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#FF0D0D0D"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        SizeChanged="Window_SizeChanged">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <Border Grid.Row="0" Background="#FF1A1A1A" Padding="10,8"
                MouseLeftButtonDown="BlankArea_MouseDown">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="OpenBtn" MinWidth="60"
                            Click="OpenBtn_Click"
                            Background="#FF4F46E5" Foreground="White" BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="12,4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="OpenBtnText" Text="导入音频"
                                       Foreground="White" FontWeight="Bold" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock x:Name="FileNameText" Text="未加载音频"
                               Foreground="#FF666666" VerticalAlignment="Center"
                               Margin="12,0,0,0" FontSize="12" MaxWidth="200"
                               TextTrimming="CharacterEllipsis"/>

                    <Button x:Name="PlayPauseBtn" MinWidth="60"
                            Click="PlayPauseBtn_Click" Margin="16,0,0,0"
                            Background="#FF1E3A5F" Foreground="White" BorderThickness="0"
                            Cursor="Hand" IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="12,4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="PlayPauseEmoji" Text="▶️"
                                     FontFamily="Segoe UI Emoji" FontSize="14"
                                     Foreground="White" Background="Transparent" BorderThickness="0"
                                     IsReadOnly="True" IsHitTestVisible="False"
                                     TextOptions.TextFormattingMode="Display"
                                     VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="PlayPauseText" Text="播放"
                                       Foreground="White" FontWeight="Bold" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="StopBtn" MinWidth="60"
                            Click="StopBtn_Click" Margin="8,0,0,0"
                            Background="#FF3A1E1E" Foreground="White" BorderThickness="0"
                            Cursor="Hand" IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="12,4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="⏮️"
                                     FontFamily="Segoe UI Emoji" FontSize="14"
                                     Foreground="White" Background="Transparent" BorderThickness="0"
                                     IsReadOnly="True" IsHitTestVisible="False"
                                     TextOptions.TextFormattingMode="Display"
                                     VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="StopBtnText" Text="开头"
                                       Foreground="White" FontWeight="Bold" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="MetronomeBtn" MinWidth="60"
                            Click="MetronomeBtn_Click" Margin="8,0,0,0"
                            Background="#FF1E6B3A" Foreground="White" BorderThickness="0"
                            Cursor="Hand" IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="12,4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="MetronomeEmoji" Text="🔊"
                                     FontFamily="Segoe UI Emoji" FontSize="14"
                                     Foreground="White" Background="Transparent" BorderThickness="0"
                                     IsReadOnly="True" IsHitTestVisible="False"
                                     TextOptions.TextFormattingMode="Display"
                                     VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="MetronomeText" Text="节拍器"
                                       Foreground="White" FontWeight="Bold" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Button x:Name="HelpBtn" Content="{lex:Loc OperationHelp_Btn}"
                            Click="HelpBtn_Click"
                            Background="#FF3A3A3A" Foreground="White" BorderThickness="0"
                            Cursor="Hand" FontSize="11" Margin="0,0,10,0" Padding="8,4">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Margin="8,4"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock x:Name="TimeText" Text="0.000s"
                               Foreground="#FF818CF8" VerticalAlignment="Center"
                               FontSize="18" FontWeight="Bold"
                               FontFamily="Consolas" Margin="0,0,12,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Visualization Area -->
        <Grid Grid.Row="1" Background="#FF0A0A0A">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Column 0: Visualization Area with sub-grid -->
            <Grid Grid.Column="0" x:Name="VizGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.5*"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="0.5*"/>
                </Grid.RowDefinitions>

                <!-- Waveform: Canvas + WriteableBitmap (GPU composited, zero CPU per-frame) -->
                <Canvas x:Name="WaveformCanvas" Grid.Row="0"
                        ClipToBounds="True" Background="#FF0A0A0A"
                        Visibility="Collapsed"
                        SizeChanged="WaveformCanvas_SizeChanged">
                    <Image x:Name="WaveformImage" Stretch="None"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="WaveScale" />
                                <TranslateTransform x:Name="WaveTranslate" />
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                </Canvas>

                <!-- Beat Row: narrow strip between waveform and spectrogram for beat numbers and drag -->
                <Canvas x:Name="BeatRowCanvas" Grid.Row="1"
                        ClipToBounds="True" Background="#FF2A2A2A"
                        Visibility="Collapsed"/>

                <!-- Spectrogram: Canvas + WriteableBitmap (GPU composited, zero CPU per-frame) -->
                <Canvas x:Name="SpectrogramCanvas" Grid.Row="2"
                        ClipToBounds="True" Background="#FF0A0A0A"
                        Visibility="Collapsed"
                        SizeChanged="SpectrogramCanvas_SizeChanged">
                    <Image x:Name="SpectrogramImage" Stretch="None"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="SpecScale" />
                                <TranslateTransform x:Name="SpecTranslate" />
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                </Canvas>

                <!-- Overlay: beat grid lines + playhead, captures mouse input -->
                <Canvas x:Name="OverlayCanvas" Grid.RowSpan="3"
                        ClipToBounds="True" Background="Transparent"
                        Visibility="Collapsed"
                        MouseLeftButtonDown="OverlayCanvas_MouseDown"
                        MouseMove="OverlayCanvas_MouseMove"
                        MouseLeftButtonUp="OverlayCanvas_MouseUp"
                        PreviewMouseWheel="OverlayCanvas_MouseWheel"/>

                <!-- Empty state placeholder -->
                <TextBlock x:Name="PlaceholderText" Grid.RowSpan="3"
                           Text="拖放音频文件到此处，或点击「导入音频」按钮"
                           Foreground="#FF333333" FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Loading indicator -->
                <TextBlock x:Name="LoadingText" Grid.RowSpan="3"
                           Text="正在加载..."
                           Foreground="#FF818CF8" FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>

                <!-- Focus highlight overlay: covers all three rows of VizGrid.
                     Thickness fixed at 2; only BorderBrush switches (transparent ↔ indigo),
                     so there is no layout shift. Non-hit-test so it never blocks mouse input. -->
                <Border x:Name="PlotAreaHighlight" Grid.RowSpan="3"
                        BorderBrush="Transparent" BorderThickness="2"
                        IsHitTestVisible="False" Panel.ZIndex="100"/>
            </Grid>

            <!-- Column 1: Right Sidebar Panel -->
            <Border Grid.Column="1" x:Name="SidebarPanel"
                    Background="#FF111111" BorderBrush="#FF222222" BorderThickness="1,0,0,0"
                    PreviewMouseLeftButtonDown="SidebarPanel_PreviewMouseDown"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Import/Export Buttons -->
                    <Border Grid.Row="0" Background="#FF141414" Padding="14,10"
                            BorderBrush="#FF222222" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="ImportConfigBtn"
                                    Click="ImportConfigBtn_Click"
                                    Background="#FF2A3050" Foreground="#FFA0A0CC"
                                    BorderThickness="0" Cursor="Hand"
                                    FontSize="12" FontWeight="Bold">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="8,4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="ImportConfigText" Text="导入配置" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="ExportConfigBtn"
                                    Click="ExportConfigBtn_Click" Margin="6,0,0,0"
                                    Background="#FF2A3050" Foreground="#FFA0A0CC"
                                    BorderThickness="0" Cursor="Hand"
                                    FontSize="12" FontWeight="Bold">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="8,4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="ExportConfigText" Text="导出配置" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Section: Global Offset -->
                    <Border Grid.Row="1" Background="#FF141414" Padding="14,10"
                            BorderBrush="#FF222222" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="OffsetLabel" Grid.Row="0"
                                       Text="{lex:Loc GlobalOffset_Label}"
                                       Foreground="#FF888888" FontSize="10" FontWeight="Bold"
                                       Margin="0,0,0,0"/>

                            <local:StepperInput x:Name="OffsetStepper" Grid.Row="2"/>
                        </Grid>
                    </Border>

                    <!-- Section: Segments (multi-BPM) -->
                    <Border Grid.Row="2" Background="#FF141414" Padding="14,10"
                            BorderBrush="#FF222222" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header: title + Add button -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SegmentsHeader" Grid.Column="0"
                                           Text="{lex:Loc Segments_Title}"
                                           Foreground="#FF888888" FontSize="10" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="AddSegmentBtn" Grid.Column="1"
                                        Click="AddSegmentBtn_Click"
                                        Background="#FF1E2A50" BorderThickness="0"
                                        Cursor="Hand" Padding="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Padding="8,3">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock x:Name="AddSegmentText" Text="+ 添加"
                                               Foreground="#FF818CF8" FontSize="11" FontWeight="Bold"/>
                                </Button>
                            </Grid>

                            <!-- Scrollable segment list (built dynamically) -->
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden">
                                <StackPanel x:Name="SegmentListPanel"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Focus highlight overlay: covers all three rows of the sidebar.
                         Thickness fixed at 2; only BorderBrush switches (transparent ↔ indigo),
                         so there is no layout shift. Non-hit-test so it never blocks child input. -->
                    <Border x:Name="SidebarHighlight" Grid.RowSpan="3"
                            BorderBrush="Transparent" BorderThickness="2"
                            IsHitTestVisible="False" Panel.ZIndex="100"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="2" Background="#FF1A1A1A" Padding="10,4"
                MouseLeftButtonDown="BlankArea_MouseDown">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Foreground="#FF555555" FontSize="11" VerticalAlignment="Center">
                        <Run Text="{lex:Loc SampleRate}"/>
                        <Run x:Name="SampleRateText" Text="-"/>
                    </TextBlock>
                    <TextBlock Foreground="#FF555555" FontSize="11" VerticalAlignment="Center" Margin="20,0,0,0">
                        <Run Text="{lex:Loc Duration}"/>
                        <Run x:Name="DurationText" Text="-"/>
                    </TextBlock>
                </StackPanel>
                <TextBlock x:Name="FpsText" HorizontalAlignment="Right"
                           Foreground="#FF555555" FontSize="11" VerticalAlignment="Center"
                           Text="FPS: -"/>
            </Grid>
        </Border>
    </Grid>
</Window>

