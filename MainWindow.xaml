<Window x:Class="BpmMeasurer.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lex="http://wpflocalizeextension.codeplex.com"
        xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        lex:LocalizeDictionary.DesignCulture="zh-CN"
        lex:ResxLocalizationProvider.DefaultAssembly="BpmMeasurer.Wpf"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
        Title="{lex:Loc WindowTitle}" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#FF0D0D0D"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        SizeChanged="Window_SizeChanged">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <Border Grid.Row="0" Background="#FF1A1A1A" Padding="10,8">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="OpenBtn" Content="导入音频" MinWidth="60" Height="28"
                            Click="OpenBtn_Click"
                            Background="#FF4F46E5" Foreground="White" BorderThickness="0"
                            FontWeight="Bold" FontSize="12" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="16,4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock x:Name="FileNameText" Text="未加载音频"
                               Foreground="#FF666666" VerticalAlignment="Center"
                               Margin="12,0,0,0" FontSize="12" MaxWidth="200"
                               TextTrimming="CharacterEllipsis"/>

                    <Button x:Name="PlayPauseBtn" Content="▶ 播放" MinWidth="60" Height="28"
                            Click="PlayPauseBtn_Click" Margin="16,0,0,0"
                            Background="#FF1E3A5F" Foreground="White" BorderThickness="0"
                            FontWeight="Bold" FontSize="12" Cursor="Hand"
                            IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="16,4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="StopBtn" Content="■ 停止" MinWidth="60" Height="28"
                            Click="StopBtn_Click" Margin="8,0,0,0"
                            Background="#FF3A1E1E" Foreground="White" BorderThickness="0"
                            FontWeight="Bold" FontSize="12" Cursor="Hand"
                            IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="16,4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <TextBlock x:Name="TimeText" Text="0.000s"
                           Foreground="#FF818CF8" VerticalAlignment="Center"
                           HorizontalAlignment="Right" FontSize="18" FontWeight="Bold"
                           FontFamily="Consolas" Margin="0,0,12,0"/>
            </Grid>
        </Border>

        <!-- Visualization Area -->
        <Grid Grid.Row="1" x:Name="VizGrid" Background="#FF0A0A0A">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.5*"/>
                <RowDefinition Height="0.5*"/>
            </Grid.RowDefinitions>

            <sp:WpfPlot x:Name="WaveformPlot" Grid.Row="0"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Visibility="Collapsed"/>
            <!-- Spectrogram: Canvas + WriteableBitmap (GPU composited, zero CPU per-frame) -->
            <Canvas x:Name="SpectrogramCanvas" Grid.Row="1"
                    ClipToBounds="True" Background="#FF0A0A0A"
                    Visibility="Collapsed"
                    SizeChanged="SpectrogramCanvas_SizeChanged">
                <Image x:Name="SpectrogramImage" Stretch="None"
                       RenderOptions.BitmapScalingMode="NearestNeighbor">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="SpecScale" />
                            <TranslateTransform x:Name="SpecTranslate" />
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
                <Line x:Name="SpecPlayheadLine"
                      Stroke="#FF00FF88" StrokeThickness="2"
                      Y1="0" />
            </Canvas>

            <!-- Empty state placeholder -->
            <TextBlock x:Name="PlaceholderText" Grid.RowSpan="2"
                       Text="拖放音频文件到此处，或点击「导入音频」按钮"
                       Foreground="#FF333333" FontSize="16" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Loading indicator -->
            <TextBlock x:Name="LoadingText" Grid.RowSpan="2"
                       Text="正在加载..."
                       Foreground="#FF818CF8" FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed"/>
        </Grid>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="2" Background="#FF1A1A1A" Padding="10,4">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Foreground="#FF555555" FontSize="11" VerticalAlignment="Center">
                        <Run Text="{lex:Loc SampleRate}"/>
                        <Run x:Name="SampleRateText" Text="-"/>
                    </TextBlock>
                    <TextBlock Foreground="#FF555555" FontSize="11" VerticalAlignment="Center" Margin="20,0,0,0">
                        <Run Text="{lex:Loc Duration}"/>
                        <Run x:Name="DurationText" Text="-"/>
                    </TextBlock>
                    <TextBlock Foreground="#FF555555" FontSize="11" VerticalAlignment="Center" Margin="20,0,0,0">
                        <Run Text="{lex:Loc Channels}"/>
                        <Run x:Name="ChannelsText" Text="-"/>
                    </TextBlock>
                </StackPanel>
                <TextBlock x:Name="FpsText" HorizontalAlignment="Right"
                           Foreground="#FF555555" FontSize="11" VerticalAlignment="Center"
                           Text="FPS: -"/>
            </Grid>
        </Border>
    </Grid>
</Window>
